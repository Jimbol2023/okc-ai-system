generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum LeadStatus {
  new
  contacted
  negotiating
  under_contract
  closed
}

model Lead {
  id              String @id @default(uuid())
  name            String
  phone           String
  propertyAddress String
  source          String

  status   LeadStatus @default(new)
  score    Int        @default(0)
  priority String     @default("Low")

  notes   String?
  payload String?

  // ============================
  // 📞 FOLLOW-UP AUTOMATION CORE
  // ============================
  lastContactedAt     DateTime?
  nextFollowUpAt      DateTime?
  followUpCount       Int       @default(0)
  lastFollowUpMessage String?
  automationStatus    String    @default("idle")
  isHot               Boolean   @default(false)

  // ============================
  // 🤖 AI REPLY BRAIN (Step 2B.7G)
  // ============================
  lastSellerReply           String?
  lastSellerReplyAt         DateTime?
  lastSellerReplyIntent     String?
  lastSellerReplyConfidence Float?
  suggestedReply            String?
  requiresHumanApproval     Boolean   @default(false)

  // ============================
  // 🔐 DNC / OPT-OUT PROTECTION
  // ============================
  doNotContact Boolean   @default(false)
  optOutReason String?
  optOutAt     DateTime?

  // ============================
  // 📊 SYSTEM TIMESTAMPS
  // ============================
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ============================
  // ⚡ INDEXES (PERFORMANCE)
  // ============================
  @@unique([propertyAddress, phone])
  @@index([createdAt])
  @@index([score, createdAt])
  @@index([status])
  @@index([nextFollowUpAt])
  @@index([isHot])
  @@index([doNotContact])
  // NEW: helpful for AI-driven queries later
  @@index([lastSellerReplyIntent])
}
